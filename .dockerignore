# Build the image from a clean tree — deps and dist are regenerated inside it
node_modules
dist
dist-ssr

# Never bake secrets into the image (env is injected at runtime via compose)
.env
.env.*

# VCS / editor / OS noise
.git
.gitignore
.vscode
.idea
.DS_Store

# Logs and build caches
*.log
*.tsbuildinfo

# Docs / deploy files not needed in the image
README.md
docker-compose.yml
Caddyfile
